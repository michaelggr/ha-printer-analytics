# Home Assistant 配置
# 根据实际设备自动生成

homeassistant:
  name: 我的家
  latitude: 30.6492247
  longitude: 114.5766169
  elevation: 0
  unit_system: metric
  time_zone: Asia/Shanghai
  currency: CNY
  country: CN
  language: zh-Hans

# Lovelace 配置（新版语法）
lovelace:
  resource_mode: yaml
  dashboards:
    lovelace:
      mode: yaml
      filename: ui-lovelace.yaml
      title: 我的智能家居
      icon: mdi:home
      show_in_sidebar: true

# ==================== 模板传感器配置（新版语法） ====================
template:
  - sensor:
      # 总实时功率
      - name: 总实时功率
        unique_id: total_power_consumption
        unit_of_measurement: W
        icon: mdi:flash
        state: >
          {{ 
            (states('sensor.wiing_cn_1169773877_v8icm_electric_power_p_4_2')|float(0) +
             states('sensor.cuco_cn_2025564050_v3_electric_power_p_11_2')|float(0) +
             states('sensor.lumi_cn_684959720_mcn02_electric_power_p_5_1')|float(0) +
             states('sensor.giot_cn_1162898415_v8icm_electric_power_p_4_2')|float(0) +
             states('sensor.giot_cn_1162942256_v8icm_electric_power_p_4_2')|float(0) +
             states('sensor.giot_cn_1163256502_v8icm_electric_power_p_4_2')|float(0) +
             states('sensor.giot_cn_1164778814_v8icm_electric_power_p_4_2')|float(0) +
             states('sensor.sixwgh_cn_1200175237_v8icm1_electric_power_p_4_2')|float(0) +
             states('sensor.cuco_cn_860509913_v3_electric_power_p_11_2')|float(0)
            )|round(2)
          }}

      # 今日总用电量
      - name: 今日总用电量
        unique_id: daily_energy_total
        unit_of_measurement: kWh
        icon: mdi:counter
        state: >
          {% set ns = namespace(total=0) %}
          {% set sensors = [
            'sensor.doujiangji_daily_kwh',
            'sensor.oven_daily_kwh',
            'sensor.heater_daily_kwh',
            'sensor.computer_daily_kwh',
            'sensor.nas_daily_kwh',
            'sensor.xiaoheinu_daily_kwh',
            'sensor.daheinu_daily_kwh',
            'sensor.washer_daily_kwh'
          ] %}
          {% for s in sensors %}
            {% set ns.total = ns.total + states(s)|float(0) %}
          {% endfor %}
          {{ ns.total|round(4) }}

      # 区域停留时长统计（分钟）
      - name: 客厅停留时长
        unique_id: living_room_duration
        unit_of_measurement: 分钟
        icon: mdi:sofa
        state: "{{ (states('input_number.living_room_duration')|float(0) / 60)|round(0) }}"

      - name: 卧室停留时长
        unique_id: bedroom_duration
        unit_of_measurement: 分钟
        icon: mdi:bed
        state: "{{ (states('input_number.bedroom_duration')|float(0) / 60)|round(0) }}"

      - name: 厨房停留时长
        unique_id: kitchen_duration
        unit_of_measurement: 分钟
        icon: mdi:stove
        state: "{{ (states('input_number.kitchen_duration')|float(0) / 60)|round(0) }}"

      - name: 餐厅停留时长
        unique_id: dining_duration
        unit_of_measurement: 分钟
        icon: mdi:silverware-fork-knife
        state: "{{ (states('input_number.dining_duration')|float(0) / 60)|round(0) }}"

      - name: 卫生间停留时长
        unique_id: bathroom_duration
        unit_of_measurement: 分钟
        icon: mdi:toilet
        state: "{{ (states('input_number.bathroom_duration')|float(0) / 60)|round(0) }}"

      - name: 走廊玄关停留时长
        unique_id: hallway_duration
        unit_of_measurement: 分钟
        icon: mdi:door
        state: "{{ (states('input_number.hallway_duration')|float(0) / 60)|round(0) }}"

      - name: 门口停留时长
        unique_id: doorway_duration
        unit_of_measurement: 分钟
        icon: mdi:door-open
        state: "{{ (states('input_number.doorway_duration')|float(0) / 60)|round(0) }}"

      # 最常访问区域
      - name: 今日最常访问区域
        unique_id: most_visited_area_today
        icon: mdi:trophy
        state: >
          {% set areas = {
            '客厅': states('counter.living_room_visits')|int(0),
            '卧室': states('counter.bedroom_visits')|int(0),
            '厨房': states('counter.kitchen_visits')|int(0),
            '餐厅': states('counter.dining_visits')|int(0),
            '卫生间': states('counter.bathroom_visits')|int(0),
            '走廊玄关': states('counter.hallway_visits')|int(0),
            '门口': states('counter.doorway_visits')|int(0)
          } %}
          {% set max_visits = areas.values()|max %}
          {% if max_visits > 0 %}
            {% for area, count in areas.items() if count == max_visits %}{{ area }} ({{ count }}次){% endfor %}
          {% else %}
            暂无数据
          {% endif %}

      # 最长停留区域
      - name: 今日最长停留区域
        unique_id: longest_stay_area_today
        icon: mdi:clock
        state: >
          {% set areas = {
            '客厅': states('sensor.living_room_duration')|int(0),
            '卧室': states('sensor.bedroom_duration')|int(0),
            '厨房': states('sensor.kitchen_duration')|int(0),
            '餐厅': states('sensor.dining_duration')|int(0),
            '卫生间': states('sensor.bathroom_duration')|int(0),
            '走廊玄关': states('sensor.hallway_duration')|int(0),
            '门口': states('sensor.doorway_duration')|int(0)
          } %}
          {% set max_duration = areas.values()|max %}
          {% if max_duration > 0 %}
            {% for area, duration in areas.items() if duration == max_duration %}{{ area }} ({{ duration }}分钟){% endfor %}
          {% else %}
            暂无数据
          {% endif %}

      # 电费估算（按0.6元/度计算）
      - name: 今日电费
        unique_id: daily_energy_cost
        unit_of_measurement: 元
        icon: mdi:currency-cny
        state: "{{ (states('sensor.jin_ri_zong_yong_dian_liang_3')|float(0) * 0.6)|round(2) }}"

      - name: 本月电费
        unique_id: monthly_energy_cost
        unit_of_measurement: 元
        icon: mdi:currency-cny
        state: "{{ (states('sensor.jin_ri_zong_yong_dian_liang_3')|float(0) * 0.6 * 30)|round(2) }}"

      - name: 本年电费
        unique_id: yearly_energy_cost
        unit_of_measurement: 元
        icon: mdi:currency-cny
        state: "{{ (states('sensor.jin_ri_zong_yong_dian_liang_3')|float(0) * 0.6 * 365)|round(2) }}"

      # 周/月/年用电量
      - name: 本周用电
        unique_id: weekly_energy_total
        unit_of_measurement: kWh
        icon: mdi:calendar-week
        state: "{{ (states('sensor.jin_ri_zong_yong_dian_liang_3')|float(0) * 7)|round(2) }}"

      - name: 本月用电
        unique_id: monthly_energy_total
        unit_of_measurement: kWh
        icon: mdi:calendar-month
        state: "{{ (states('sensor.jin_ri_zong_yong_dian_liang_3')|float(0) * 30)|round(2) }}"

      - name: 本年用电
        unique_id: yearly_energy_total
        unit_of_measurement: kWh
        icon: mdi:calendar
        state: "{{ (states('sensor.jin_ri_zong_yong_dian_liang_3')|float(0) * 365)|round(2) }}"

      # ==================== 灯亮时长统计（区域汇总） ====================
      - name: 客厅灯今日亮灯时长
        unique_id: living_room_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_jdjz_duration')|float(0) + states('input_number.light_sofa_duration')|float(0)) / 60)|round(0) }}"

      - name: 卧室灯今日亮灯时长
        unique_id: bedroom_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_bedroom_duration')|float(0) + states('input_number.light_bedroom_strip_duration')|float(0)) / 60)|round(0) }}"

      - name: 厨房灯今日亮灯时长
        unique_id: kitchen_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_kitchen_duration')|float(0) / 60)|round(0) }}"

      - name: 餐厅灯今日亮灯时长
        unique_id: dining_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_dining_duration')|float(0) / 60)|round(0) }}"

      - name: 卫生间灯今日亮灯时长
        unique_id: bathroom_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_bathroom_duration')|float(0) + states('input_number.light_yuba_duration')|float(0)) / 60)|round(0) }}"

      - name: 走廊灯今日亮灯时长
        unique_id: hallway_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_hallway_main_duration')|float(0) + states('input_number.light_hallway_bath_duration')|float(0)) / 60)|round(0) }}"

      - name: 门口灯今日亮灯时长
        unique_id: doorway_light_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_doorway_duration')|float(0) / 60)|round(0) }}"

      # 今日亮灯总时长
      - name: 今日亮灯总时长
        unique_id: total_light_duration_today
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-group-on
        state: >
          {{ 
            (states('sensor.living_room_light_duration_min')|float(0) +
             states('sensor.bedroom_light_duration_min')|float(0) +
             states('sensor.kitchen_light_duration_min')|float(0) +
             states('sensor.dining_light_duration_min')|float(0) +
             states('sensor.bathroom_light_duration_min')|float(0) +
             states('sensor.hallway_light_duration_min')|float(0) +
             states('sensor.doorway_light_duration_min')|float(0)
            )|round(0)
          }}

      # ==================== 每个灯亮灯时长（分钟） ====================
      - name: 客厅吸顶灯亮灯时长
        unique_id: light_jdjz_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_jdjz_duration')|float(0) / 60)|round(0) }}"

      - name: 客厅沙发灯亮灯时长
        unique_id: light_sofa_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_sofa_duration')|float(0) / 60)|round(0) }}"

      - name: 卧室灯亮灯时长
        unique_id: light_bedroom_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_bedroom_duration')|float(0) / 60)|round(0) }}"

      - name: 卧室灯带亮灯时长
        unique_id: light_bedroom_strip_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_bedroom_strip_duration')|float(0) / 60)|round(0) }}"

      - name: 厨房灯亮灯时长
        unique_id: light_kitchen_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_kitchen_duration')|float(0) / 60)|round(0) }}"

      - name: 餐厅灯亮灯时长
        unique_id: light_dining_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_dining_duration')|float(0) / 60)|round(0) }}"

      - name: 卫生间灯亮灯时长
        unique_id: light_bathroom_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_bathroom_duration')|float(0) / 60)|round(0) }}"

      - name: 浴霸灯亮灯时长
        unique_id: light_yuba_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_yuba_duration')|float(0) / 60)|round(0) }}"

      - name: 走廊走道灯亮灯时长
        unique_id: light_hallway_main_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_hallway_main_duration')|float(0) / 60)|round(0) }}"

      - name: 走廊卫生间灯亮灯时长
        unique_id: light_hallway_bath_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_hallway_bath_duration')|float(0) / 60)|round(0) }}"

      - name: 门口筒灯亮灯时长
        unique_id: light_doorway_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-on
        state: "{{ (states('input_number.light_doorway_duration')|float(0) / 60)|round(0) }}"

      # ==================== 全屋灯光总亮灯时长（秒） ====================
      - name: 全屋灯光总亮灯时长
        unique_id: total_lights_duration
        unit_of_measurement: 秒
        icon: mdi:lightbulb-group-on
        state: >
          {{ 
            (states('input_number.light_jdjz_duration')|float(0) +
             states('input_number.light_sofa_duration')|float(0) +
             states('input_number.light_bedroom_duration')|float(0) +
             states('input_number.light_bedroom_strip_duration')|float(0) +
             states('input_number.light_kitchen_duration')|float(0) +
             states('input_number.light_dining_duration')|float(0) +
             states('input_number.light_bathroom_duration')|float(0) +
             states('input_number.light_yuba_duration')|float(0) +
             states('input_number.light_hallway_main_duration')|float(0) +
             states('input_number.light_hallway_bath_duration')|float(0) +
             states('input_number.light_doorway_duration')|float(0)
            )|round(0)
          }}

      - name: 全屋灯光总亮灯时长分钟
        unique_id: total_lights_duration_min
        unit_of_measurement: 分钟
        icon: mdi:lightbulb-group-on
        state: "{{ (states('sensor.quan_wu_deng_guang_zong_liang_deng_shi_chang')|float(0) / 60)|round(0) }}"

      - name: 全屋灯光总亮灯时长小时
        unique_id: total_lights_duration_hour
        unit_of_measurement: 小时
        icon: mdi:lightbulb-group-on
        state: "{{ (states('sensor.quan_wu_deng_guang_zong_liang_deng_shi_chang')|float(0) / 3600)|round(2) }}"

      # ==================== 小黑奴 (小打印机) kWh 转换传感器 ====================
      - name: XiaoHeiNu Daily Energy kWh
        unique_id: xiaoheinu_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.xiaoheinu_daily_energy')|float(0) / 1000000)|round(4) }}"

      - name: XiaoHeiNu Weekly Energy kWh
        unique_id: xiaoheinu_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.xiaoheinu_weekly_energy')|float(0) / 1000000)|round(4) }}"

      - name: XiaoHeiNu Monthly Energy kWh
        unique_id: xiaoheinu_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.xiaoheinu_monthly_energy')|float(0) / 1000000)|round(4) }}"

      - name: XiaoHeiNu Total Energy kWh
        unique_id: xiaoheinu_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.giot_cn_1164778814_v8icm_power_consumption_p_4_1')|float(0) / 1000000)|round(4) }}"

      # ==================== 大黑奴 (大打印机) kWh 转换传感器 ====================
      # 注意：大黑奴原始单位可能是 Wh，需要除以 1000 转换成 kWh
      - name: DaHeiNu Daily Energy kWh
        unique_id: daheinu_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.daheinu_daily_energy')|float(0) / 1000)|round(4) }}"

      - name: DaHeiNu Weekly Energy kWh
        unique_id: daheinu_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.daheinu_weekly_energy')|float(0) / 1000)|round(4) }}"

      - name: DaHeiNu Monthly Energy kWh
        unique_id: daheinu_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.daheinu_monthly_energy')|float(0) / 1000)|round(4) }}"

      - name: DaHeiNu Total Energy kWh
        unique_id: daheinu_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.sixwgh_cn_1200175237_v8icm1_power_consumption_p_4_1')|float(0) / 1000)|round(4) }}"

      # ==================== 电脑电源 kWh 转换传感器 ====================
      - name: 电脑电源今日用电_kwh
        unique_id: computer_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.computer_daily_energy')|float(0) / 1000000)|round(4) }}"

      - name: 电脑电源本周用电_kwh
        unique_id: computer_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.computer_weekly_energy')|float(0) / 1000000)|round(4) }}"

      - name: 电脑电源本月用电_kwh
        unique_id: computer_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.computer_monthly_energy')|float(0) / 1000000)|round(4) }}"

      - name: 电脑电源累计用电_kwh
        unique_id: computer_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.giot_cn_1162942256_v8icm_power_consumption_p_4_1')|float(0) / 1000000)|round(4) }}"

      # ==================== NAS kWh 转换传感器 ====================
      - name: NAS今日用电_kwh
        unique_id: nas_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.nas_daily_energy')|float(0) / 1000000)|round(4) }}"

      - name: NAS本周用电_kwh
        unique_id: nas_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.nas_weekly_energy')|float(0) / 1000000)|round(4) }}"

      - name: NAS本月用电_kwh
        unique_id: nas_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.nas_monthly_energy')|float(0) / 1000000)|round(4) }}"

      - name: NAS累计用电_kwh
        unique_id: nas_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.giot_cn_1163256502_v8icm_power_consumption_p_4_1')|float(0) / 1000000)|round(4) }}"

      # ==================== 取暖器 kWh 转换传感器 ====================
      - name: 取暖器今日用电_kwh
        unique_id: heater_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.heater_daily_energy')|float(0) / 1000000)|round(4) }}"

      - name: 取暖器本周用电_kwh
        unique_id: heater_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.heater_weekly_energy')|float(0) / 1000000)|round(4) }}"

      - name: 取暖器本月用电_kwh
        unique_id: heater_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.heater_monthly_energy')|float(0) / 1000000)|round(4) }}"

      - name: 取暖器累计用电_kwh
        unique_id: heater_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ (states('sensor.giot_cn_1162898415_v8icm_power_consumption_p_4_1')|float(0) / 1000000)|round(4) }}"

      # ==================== 豆浆机 kWh 转换传感器 ====================
      # 注意：豆浆机原始单位是 kWh，不需要转换
      - name: 豆浆机今日用电_kwh
        unique_id: doujiangji_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.doujiangji_daily_energy')|float(0)|round(4) }}"

      - name: 豆浆机本周用电_kwh
        unique_id: doujiangji_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.doujiangji_weekly_energy')|float(0)|round(4) }}"

      - name: 豆浆机本月用电_kwh
        unique_id: doujiangji_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.doujiangji_monthly_energy')|float(0)|round(4) }}"

      - name: 豆浆机累计用电_kwh
        unique_id: doujiangji_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.wiing_cn_1169773877_v8icm_power_consumption_p_4_1')|float(0)|round(4) }}"

      # ==================== 烤箱 kWh 转换传感器 ====================
      # 注意：烤箱原始单位是 kWh，不需要转换
      - name: 烤箱今日用电_kwh
        unique_id: oven_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.oven_daily_energy')|float(0)|round(4) }}"

      - name: 烤箱本周用电_kwh
        unique_id: oven_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.oven_weekly_energy')|float(0)|round(4) }}"

      - name: 烤箱本月用电_kwh
        unique_id: oven_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.oven_monthly_energy')|float(0)|round(4) }}"

      - name: 烤箱累计用电_kwh
        unique_id: oven_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.cuco_cn_2025564050_v3_power_consumption_p_11_1')|float(0)|round(4) }}"

      # ==================== 洗衣机 kWh 转换传感器 ====================
      # 注意：洗衣机原始单位是 kWh，不需要转换
      - name: 洗衣机今日用电_kwh
        unique_id: washer_daily_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.washer_daily_energy')|float(0)|round(4) }}"

      - name: 洗衣机本周用电_kwh
        unique_id: washer_weekly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.washer_weekly_energy')|float(0)|round(4) }}"

      - name: 洗衣机本月用电_kwh
        unique_id: washer_monthly_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.washer_monthly_energy')|float(0)|round(4) }}"

      - name: 洗衣机累计用电_kwh
        unique_id: washer_total_kwh
        unit_of_measurement: kWh
        icon: mdi:counter
        state: "{{ states('sensor.cuco_cn_860509913_v3_power_consumption_p_11_1')|float(0)|round(4) }}"

