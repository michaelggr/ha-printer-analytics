    cycle: monthly
    name: 全屋灯光月亮灯时长小时

# ==================== MQTT 设备配置 ====================
mqtt:
  fan:
    name: 'za1_b0f8932cb0ca'
    unique_id: za1_b0f8932cb0ca
    state_topic: "device/za1/b0f8932cb0ca/state"
    command_topic: "device/za1/b0f8932cb0ca/set"
    payload_on: '{"mac":"b0f8932cb0ca","on":1}'
    payload_off: '{"mac":"b0f8932cb0ca","on":0}'
    state_value_template: |
      {%- if value_json.on == 0 -%}
      {"mac":"b0f8932cb0ca","on":0}
      {%- else -%}
      {"mac":"b0f8932cb0ca","on":1}
      {%- endif %}
    qos: 0
    percentage_state_topic: "device/za1/b0f8932cb0ca/state"
    percentage_command_topic: "device/za1/b0f8932cb0ca/set"
    percentage_command_template: '{"mac":"b0f8932cb0ca","speed":{{ value }}}'
    percentage_value_template: '{{ value_json.speed }}'
  sensor:
    - name: 'zm1_b0f8931ee681_temperature'
      unique_id: zm1_b0f8931ee681_temperature
      device_class: temperature
      state_topic: 'device/zm1/b0f8931ee681/sensor'
      unit_of_measurement: '°C'
      value_template: '{{ value_json.temperature }}'
      availability_topic: "device/zm1/b0f8931ee681/availability"
      payload_available: 1
      payload_not_available: 0

    - name: 'zm1_b0f8931ee681_humidity'
      unique_id: zm1_b0f8931ee681_humidity
      device_class: humidity
      state_topic: 'device/zm1/b0f8931ee681/sensor'
      unit_of_measurement: '%'
      value_template: '{{ value_json.humidity }}'
      availability_topic: "device/zm1/b0f8931ee681/availability"
      payload_available: 1
      payload_not_available: 0

    - name: 'zm1_b0f8931ee681_pm25'
      unique_id: zm1_b0f8931ee681_pm25
      device_class: pm25
      state_topic: 'device/zm1/b0f8931ee681/sensor'
      unit_of_measurement: 'μg/m³'
      value_template: '{{ value_json.PM25 }}'
      availability_topic: "device/zm1/b0f8931ee681/availability"
      payload_available: 1
      payload_not_available: 0

    - name: 'zm1_b0f8931ee681_hcho'
      unique_id: zm1_b0f8931ee681_hcho
      device_class: volatile_organic_compounds
      state_topic: 'device/zm1/b0f8931ee681/sensor'
      unit_of_measurement: 'mg/m³'
      value_template: '{{ value_json.formaldehyde }}'
      availability_topic: "device/zm1/b0f8931ee681/availability"
      payload_available: 1
      payload_not_available: 0

  light:
    - name: zm1_b0f8931ee681_brightness
      unique_id: zm1_b0f8931ee681_brightness
      schema: template
      command_topic: "device/zm1/b0f8931ee681/set"
      state_topic: "device/zm1/b0f8931ee681/state"
      command_on_template: >
        {"mac": "b0f8931ee681"
        {%- if brightness is defined -%}
        , "brightness": {{ ((brightness-1) / 64 )|int +1 }}
        {%- else -%}
        , "brightness": 4
        {%- endif -%}
        }
      command_off_template: '{"mac": "b0f8931ee681", "brightness": 0}'
      state_template: >
        {%- if value_json.brightness == 0 -%}
          off
        {%- else -%}
          on
        {%- endif -%}
      brightness_template: >
        {%- if value_json.brightness is defined -%}
          {{ ( value_json.brightness *64 )|int }}
        {%- endif -%}

