# ==================== Utility Meter 用电量统计配置 ====================
utility_meter:
  # 小打印机 (小黑奴) - 日/周/月统计
  xiaoheinu_daily_energy:
    source: sensor.giot_cn_1164778814_v8icm_power_consumption_p_4_1
    cycle: daily
    name: 小打印机日用电量
  xiaoheinu_weekly_energy:
    source: sensor.giot_cn_1164778814_v8icm_power_consumption_p_4_1
    cycle: weekly
    name: 小打印机周用电量
  xiaoheinu_monthly_energy:
    source: sensor.giot_cn_1164778814_v8icm_power_consumption_p_4_1
    cycle: monthly
    name: 小打印机月用电量

  # 大打印机 (大黑奴) - 日/周/月统计
  daheinu_daily_energy:
    source: sensor.sixwgh_cn_1200175237_v8icm1_power_consumption_p_4_1
