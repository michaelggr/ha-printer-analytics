- id: printer_error_notification
  alias: '[打印] 打印错误通知'
  mode: single
  triggers:
  - platform: state
    entity_id: binary_sensor.a1mini_0300aa5a1600497_print_error
    to: 'on'
  - platform: state
    entity_id: binary_sensor.p2s_22e8bj5a2401765_print_error
    to: 'on'
  conditions:
  - condition: state
    entity_id: sensor.linp_cn_blt_3_1n20sdaek4k01_es4b_occupancy_status_p_2_1078
    state: 有人
  actions:
  - service: notify.send_message
    target:
      entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
    data:
      message: "{% if trigger.entity_id == 'binary_sensor.a1mini_0300aa5a1600497_print_error' %}\n  注意，A1 Mini 打印机出现错误，请检查！\n\
        {% else %}\n  注意，P2S 打印机出现错误，请检查！\n{% endif %}\n"
- id: virtual_event_broadcast
  alias: '[系统] 中枢网关虚拟事件播报'
  mode: single
  triggers:
  - platform: event
    event_type: state_changed
    event_data:
      entity_id: event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1
  conditions:
  - condition: template
    value_template: '{{ trigger.to_state.state not in [''unavailable'', ''unknown'', ''''] }}'
  actions:
  - service: notify.send_message
    target:
      entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
    data:
      message: 虚拟事件发生：{{ trigger.to_state.state }}
- id: '1774512472146'
  alias: 虚拟打开电视触发红外遥控点电视音响和电视电源键
  mode: single
  triggers:
  - platform: state
    entity_id: event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1
  conditions:
  - condition: template
    value_template: '{{ state_attr(''event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1'', ''事件名称'') == ''电视电源键'' }}'
  actions:
  - service: button.press
    target:
      entity_id: button.yin_xiang_power
  - delay:
      milliseconds: 500
  - service: button.press
    target:
      entity_id: button.dian_shi_power
- id: '1774515470812'
  alias: 虚拟事件电视切网易云
  mode: single
  triggers:
  - platform: state
    entity_id: event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1
  conditions:
  - condition: template
    value_template: '{{ state_attr(''event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1'', ''事件名称'') == ''电视切网易云'' }}'
  actions:
  - service: button.press
    target:
      entity_id: button.ji_ding_he_homepage
  - delay:
      seconds: 1
  - service: button.press
    target:
      entity_id: button.ji_ding_he_1
- id: '1774516117948'
  alias: 虚拟事件电视切直播
  mode: single
  triggers:
  - platform: state
    entity_id: event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1
  conditions:
  - condition: template
    value_template: '{{ trigger.from_state is not none and trigger.to_state is not
      none and trigger.from_state.state != trigger.to_state.state }}'
  - condition: template
    value_template: '{% set ev = state_attr(''event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1'',
      ''事件名称'') | default('''') %} {{ ev in [''电视切直播'', ''电视切TV''] and
      not ev.startswith(''ACK_'') }}'
  actions:
  - service: button.press
    target:
      entity_id: button.ji_ding_he_homepage
  - delay:
      seconds: 1
  - service: button.press
    target:
      entity_id: button.ji_ding_he_2
  - service: notify.send_message
    target:
      entity_id: notify.xiaomi_cn_1175403807_hub1_emit_virtual_event_a_4_1
    data:
      message: ACK_电视切直播_{{ now().timestamp()|int }}
- id: '1774516169921'
