- id: printer_remaining_time
  alias: '[打印] 打印机剩余时间播报'
  mode: single
  triggers:
  - platform: state
    entity_id: event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1
  conditions:
  - condition: template
    value_template: '{{ state_attr(''event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1'', ''事件名称'') == ''打印剩余时间'' }}'
  actions:
  - service: notify.send_message
    target:
      entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
    data:
      message: "{% set a1mini = states('sensor.a1mini_0300aa5a1600497_remaining_time') %} {% set p2s = states('sensor.p2s_22e8bj5a2401765_remaining_time')\
        \ %} {% set now = now() %}\n{% macro format_time(hours, mins) %}\n  {% if hours > 0 and mins > 0 %}\n    {{ hours\
        \ }}小时{{ mins }}分钟\n  {% elif hours > 0 %}\n    {{ hours }}小时\n  {% elif mins > 0 %}\n    {{ mins }}分钟\n  {% else\
        \ %}\n    即将完成\n  {% endif %}\n{% endmacro %}\n{% macro get_completion_time(remaining) %}\n  {% if remaining != 'unknown'\
        \ %}\n    {{ (now + timedelta(hours=remaining | float(0))).strftime('%H:%M') }}\n  {% else %}\n    未知\n  {% endif\
        \ %}\n{% endmacro %}\n{% set a1mini_hours = a1mini | float(0) | int %} {% set a1mini_mins = ((a1mini | float(0) -\
        \ a1mini_hours) * 60) | int %} {% set p2s_hours = p2s | float(0) | int %} {% set p2s_mins = ((p2s | float(0) - p2s_hours)\
        \ * 60) | int %}\n{% if a1mini != 'unknown' and a1mini | float > 0 and p2s != 'unknown' and p2s | float > 0 %}\n \
        \ 打印中，小黑奴剩余{{ format_time(a1mini_hours, a1mini_mins) }}，预计{{ get_completion_time(a1mini) }}完成；大黑奴剩余{{ format_time(p2s_hours,\
        \ p2s_mins) }}，预计{{ get_completion_time(p2s) }}完成。\n{% elif a1mini != 'unknown' and a1mini | float > 0 %}\n  打印中，小黑奴剩余{{\
        \ format_time(a1mini_hours, a1mini_mins) }}，预计{{ get_completion_time(a1mini) }}完成。\n{% elif p2s != 'unknown' and p2s\
        \ | float > 0 %}\n  打印中，大黑奴剩余{{ format_time(p2s_hours, p2s_mins) }}，预计{{ get_completion_time(p2s) }}完成。\n{% else %}\n\
        \  当前没有正在进行的打印任务。\n{% endif %}\n"
- id: printer_completion_notification
  alias: '[打印] FDM 打印机打印完成通知'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.a1mini_0300aa5a1600497_print_status
    to: 完成
  - platform: state
    entity_id: sensor.p2s_22e8bj5a2401765_print_status
    to: 完成
  conditions:
  - condition: state
    entity_id: sensor.linp_cn_blt_3_1n20sdaek4k01_es4b_occupancy_status_p_2_1078
    state: 有人
  actions:
  - service: notify.send_message
    target:
      entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
    data:
      message: "{% if trigger.entity_id == 'sensor.a1mini_0300aa5a1600497_print_status' %}\n  {% set start = states('sensor.a1mini_0300aa5a1600497_start_time')\
        \ %}\n  {% if start != 'unknown' %}\n    {% set start_ts = as_timestamp(start) %}\n    {% set now_ts = as_timestamp(now())\
        \ %}\n    {% set duration_min = ((now_ts - start_ts) / 60) | int %}\n    {% set hours = (duration_min / 60) | int\
        \ %}\n    {% set mins = duration_min % 60 %}\n    {% if hours > 0 %}\n      小黑奴打印已完成！用时{{ hours }}小时{{ mins }}分钟。开始排气10分钟。\n\
        \    {% else %}\n      小黑奴打印已完成！用时{{ mins }}分钟。开始排气10分钟。\n    {% endif %}\n  {% else %}\n    小黑奴打印已完成！开始排气10分钟。\n\
        \  {% endif %}\n{% else %}\n  {% set start = states('sensor.p2s_22e8bj5a2401765_start_time') %}\n  {% if start !=\
        \ 'unknown' %}\n    {% set start_ts = as_timestamp(start) %}\n    {% set now_ts = as_timestamp(now()) %}\n    {% set\
        \ duration_min = ((now_ts - start_ts) / 60) | int %}\n    {% set hours = (duration_min / 60) | int %}\n    {% set\
        \ mins = duration_min % 60 %}\n    {% if hours > 0 %}\n      大黑奴打印已完成！用时{{ hours }}小时{{ mins }}分钟。开始排气10分钟。\n    {%\
        \ else %}\n      大黑奴打印已完成！用时{{ mins }}分钟。开始排气10分钟。\n    {% endif %}\n  {% else %}\n    大黑奴打印已完成！开始排气10分钟。\n  {% endif\
        \ %}\n{% endif %}\n"
- id: daheinu_exhaust_fan
  alias: '[打印] 大黑奴打印完成排气'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.p2s_22e8bj5a2401765_print_status
    to: 完成
  actions:
  - service: switch.turn_on
    data:
      entity_id: switch.sixwgh_cn_1200175237_v8icm1_on_p_2_1
  - delay:
      minutes: 10
  - service: switch.turn_off
    data:
      entity_id: switch.sixwgh_cn_1200175237_v8icm1_on_p_2_1
  - choose:
    - conditions:
      - condition: state
        entity_id: sensor.linp_cn_blt_3_1n20sdaek4k01_es4b_occupancy_status_p_2_1078
        state: 有人
      sequence:
      - service: notify.send_message
        target:
          entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
        data:
          message: 大黑奴排气完成！
- id: xiaoheinu_exhaust_fan
  alias: '[打印] 小黑奴打印完成打开排气'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.a1mini_0300aa5a1600497_print_status
    to: 完成
  actions:
  - service: switch.turn_on
    data:
      entity_id: switch.giot_cn_1164778814_v8icm_on_p_2_1
  - delay:
      minutes: 10
  - service: switch.turn_off
    data:
      entity_id: switch.giot_cn_1164778814_v8icm_on_p_2_1
  - choose:
    - conditions:
      - condition: state
        entity_id: sensor.linp_cn_blt_3_1n20sdaek4k01_es4b_occupancy_status_p_2_1078
        state: 有人
      sequence:
      - service: notify.send_message
        target:
          entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
        data:
          message: 小黑奴排气完成！
- id: ams_humidity_notification
  alias: '[打印] AMS 1 湿度大于 50 通知'
  mode: single
  triggers:
  - platform: numeric_state
    entity_id: sensor.p2s_22e8bj5a2401765_ams_1_humidity
    above: 50
  actions:
  - service: notify.send_message
    target:
      entity_id: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
    data:
      message: 注意，AMS湿度大于50%，请检查！
- id: a1mini_record_start_energy
  alias: '[打印] A1 Mini 记录开始电量'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.a1mini_0300aa5a1600497_print_status
    to: running
  actions:
  - service: input_text.set_value
    target:
      entity_id: input_text.a1mini_start_energy
    data:
      value: '{{ states(''sensor.giot_cn_1164778814_v8icm_power_consumption_p_4_1'') | float(0) }}'
- id: printer_history_a1mini
  alias: '[打印] A1 Mini 打印历史记录'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.a1mini_0300aa5a1600497_print_status
    to:
    - 失败
    - 完成
  actions:
  - service: homeassistant.set_state
    target:
      entity_id: sensor.a1mini_print_history
    data:
      state: '{{ now().strftime(''%Y-%m-%d %H:%M:%S'') }}'
      attributes:
        history: "{% set history = state_attr('sensor.a1mini_print_history', 'history') | default('[]') | from_json %} {%\
          \ set now = now().strftime('%Y-%m-%d %H:%M:%S') %} {% set status = trigger.to_state.state %} {% set progress = states('sensor.a1mini_0300aa5a1600497_print_progress')\
          \ | float(0) %} {% set total_weight = states('sensor.a1mini_0300aa5a1600497_print_weight') | float(0) %} {% set\
          \ total_length = states('sensor.a1mini_0300aa5a1600497_print_length') | float(0) %} {% set active_tray = states('sensor.a1mini_0300aa5a1600497_active_tray')\
          \ %} {% set filament_type = state_attr('sensor.a1mini_0300aa5a1600497_active_tray', 'type') %} {% set color = state_attr('sensor.a1mini_0300aa5a1600497_active_tray',\
          \ 'color') %} {% set usage_weight = (total_weight * progress / 100) | round(2) %} {% set usage_length = (total_length\
          \ * progress / 100) | round(2) %} {% set start_energy = states('input_text.a1mini_start_energy') | float(0) %} {%\
          \ set end_energy = states('sensor.giot_cn_1164778814_v8icm_power_consumption_p_4_1') | float(0) %} {% set energy\
          \ = (end_energy - start_energy) | round(2) %} {% set new_record = {\n  'time': now,\n  'status': status,\n  'progress':\
          \ progress | int,\n  'material': filament_type or 'Unknown',\n  'color': color or '#FFFFFF',\n  'total_weight':\
          \ total_weight,\n  'usage_weight': usage_weight,\n  'total_length': total_length,\n  'usage_length': usage_length,\n\
          \  'energy': energy | round(2)\n} %} {% set new_history = [new_record] + history %} {{ new_history[:50] | to_json\
          \ }}\n"
- id: p2s_record_start_energy
  alias: '[打印] P2S 记录开始电量'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.p2s_22e8bj5a2401765_print_status
    to: running
  actions:
  - service: input_text.set_value
    target:
      entity_id: input_text.p2s_start_energy
    data:
      value: '{{ states(''sensor.sixwgh_cn_1200175237_v8icm1_power_consumption_p_4_1'') | float(0) }}'
- id: printer_history_p2s
  alias: '[打印] P2S 打印历史记录'
  mode: single
  triggers:
  - platform: state
    entity_id: sensor.p2s_22e8bj5a2401765_print_status
    to:
    - 失败
    - 完成
  actions:
  - service: homeassistant.set_state
    target:
      entity_id: sensor.p2s_print_history
    data:
      state: '{{ now().strftime(''%Y-%m-%d %H:%M:%S'') }}'
      attributes:
        history: "{% set history = state_attr('sensor.p2s_print_history', 'history') | default('[]') | from_json %} {% set\
          \ now = now().strftime('%Y-%m-%d %H:%M:%S') %} {% set status = trigger.to_state.state %} {% set progress = states('sensor.p2s_22e8bj5a2401765_print_progress')\
          \ | float(0) %} {% set total_weight = states('sensor.p2s_22e8bj5a2401765_print_weight') | float(0) %} {% set total_length\
          \ = states('sensor.p2s_22e8bj5a2401765_print_length') | float(0) %} {% set active_tray = states('sensor.p2s_22e8bj5a2401765_active_tray')\
          \ %} {% set filament_type = state_attr('sensor.p2s_22e8bj5a2401765_active_tray', 'type') %} {% set color = state_attr('sensor.p2s_22e8bj5a2401765_active_tray',\
          \ 'color') %} {% set usage_weight = (total_weight * progress / 100) | round(2) %} {% set usage_length = (total_length\
          \ * progress / 100) | round(2) %} {% set start_energy = states('input_text.p2s_start_energy') | float(0) %} {% set\
          \ end_energy = states('sensor.sixwgh_cn_1200175237_v8icm1_power_consumption_p_4_1') | float(0) %} {% set energy\
          \ = (end_energy - start_energy) | round(2) %} {% set new_record = {\n  'time': now,\n  'status': status,\n  'progress':\
          \ progress | int,\n  'material': filament_type or 'Unknown',\n  'color': color or '#FFFFFF',\n  'total_weight':\
          \ total_weight,\n  'usage_weight': usage_weight,\n  'total_length': total_length,\n  'usage_length': usage_length,\n\
          \  'energy': energy | round(2)\n} %} {% set new_history = [new_record] + history %} {{ new_history[:50] | to_json\
          \ }}\n"
