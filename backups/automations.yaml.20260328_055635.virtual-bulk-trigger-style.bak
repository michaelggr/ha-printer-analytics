- id: '1774306560576'
  alias: Bambu Lab - 炒面检测 (米家通知版)
  description: ''
  use_blueprint:
    path: spaghetti_detection_xiaomi.yaml
    input:
      xiaomi_gateway_virtual_event: notify.xiaomi_cn_1175403807_hub1_emit_virtual_event_a_4_1
      alert_channels:
      - virtual_event
      - notify_message
      notify_message_target: notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1
      notify_message_text: 小黑奴炒面暂停打印请检查
      alert_threshold: 0.55
      printer_print_status_sensor: sensor.a1mini_0300aa5a1600497_print_status
      printer_current_stage_sensor: sensor.a1mini_0300aa5a1600497_current_stage
      printer_start_time_sensor: sensor.a1mini_0300aa5a1600497_start_time
      printer_camera: image.a1mini_0300aa5a1600497_camera
      enable_image_quality_check: false
      max_image_age: 180
      camera_refresh_service: image.update
      printer_pause_button: button.a1mini_0300aa5a1600497_pause_printing
      printer_resume_button: button.a1mini_0300aa5a1600497_resume_printing
      printer_stop_button: button.a1mini_0300aa5a1600497_stop_printing
      printer_chamber_light: light.a1mini_0300aa5a1600497_chamber_light
      virtual_event_name: spaghetti_detected
