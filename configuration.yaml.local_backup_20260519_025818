# Home Assistant Configuration

homeassistant:
  name: Home Assistant
  latitude: 30.64922247
  longitude: 114.5766169
  elevation: 0
  unit_system: metric
  time_zone: Asia/Shanghai
  currency: CNY
  country: CN
  language: zh-Hans
  internal_url: http://192.168.0.130:8123
  customize: !include customize.yaml

