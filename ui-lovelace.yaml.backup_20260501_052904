﻿# Home Assistant 定制仪表板配置

# 根据实际设备自动生成

# 区域：客厅、卧室、厨房、餐厅、卫生间、走廊玄关



title: 我的智能家居

views:

  # ==================== 首页 - 区域导航 ====================

  - title: 首页

    icon: mdi:home

    path: home

    cards:

      # 欢迎卡片

      - type: entities

        title: 欢迎回家

        entities:

          - entity: person.feng

            name: 家庭成员

          - entity: sun.sun

            name: 日出日落



      # 区域导航网格

      - type: grid

        title: 区域导航

        columns: 2

        cards:

          # 客厅

          - type: button

            name: 客厅

            icon: mdi:sofa

            tap_action:

              action: navigate

              navigation_path: /lovelace/living-room

            entity: sensor.linp_cn_blt_3_1n20sdaek4k01_es4b_occupancy_status_p_2_1078

            show_state: true



          # 卧室

          - type: button

            name: 卧室

            icon: mdi:bed

            tap_action:

              action: navigate

              navigation_path: /lovelace/bedroom

            entity: sensor.linp_cn_blt_3_1ocv0fv7l0o00_es5b_occupancy_status_p_2_1078

            show_state: true



          # 厨房

          - type: button

            name: 厨房

            icon: mdi:stove

            tap_action:

              action: navigate

              navigation_path: /lovelace/kitchen

            entity: sensor.linp_cn_1137697716_lp1bc_occupancy_status_p_5_1

            show_state: true



          # 餐厅

          - type: button

            name: 餐厅

            icon: mdi:silverware-fork-knife

            tap_action:

              action: navigate

              navigation_path: /lovelace/dining

            entity: sensor.linp_cn_blt_3_1n49ffqescc00_es2_occupancy_status_p_2_1078

            show_state: true



          # 卫生间

          - type: button

            name: 卫生间

            icon: mdi:toilet

            tap_action:

              action: navigate

              navigation_path: /lovelace/bathroom

            entity: sensor.linp_cn_1137691863_lp1bc_occupancy_status_p_5_1

            show_state: true



          # 走廊玄关

          - type: button

            name: 走廊玄关

            icon: mdi:door

            tap_action:

              action: navigate

              navigation_path: /lovelace/hallway

            entity: sensor.linp_cn_1161876236_hb01_occupancy_status_p_2_1

            show_state: true



          # 门口

          - type: button

            name: 门口

            icon: mdi:door-open

            tap_action:

              action: navigate

              navigation_path: /lovelace/doorway

            entity: sensor.linp_cn_2079761645_ld6bcw_has_someone_duration_p_5_3

            show_state: true



      # 快速统计

      - type: glance

        title: 快速统计

        entities:

          - entity: sensor.giot_cn_1162942256_v8icm_electric_power_p_4_2

            name: 电脑电源

          - entity: sensor.giot_cn_1164778814_v8icm_electric_power_p_4_2

            name: 小打印机

          - entity: sensor.yutai_cn_1169887446_fsov8m_electric_power_p_4_2

            name: 大打印机

          - entity: sensor.210006733703670_realtime_power

            name: 客厅空调

          - entity: sensor.208907222021213_realtime_power

            name: 卧室空调

        show_state: true

        show_icon: true



      # 灯控面板

      - type: grid

        title: 💡 灯控面板

        columns: 4

        cards:

          - type: light

            entity: light.jdjz_cn_857569251_jdjzu1_s_2_light

            name: 客厅吸顶灯

          - type: light

            entity: light.lemesh_cn_1186971184_wy0c14_s_2_light

            name: 客厅沙发灯

          - type: light

            entity: light.ftd_cn_1124827030_dsplmp_s_2_light

            name: 卧室灯

          - type: light

            entity: light.yeelink_cn_436301383_strip6_s_2_light

            name: 卧室灯带

          - type: light

            entity: light.linp_cn_1137697716_lp1bc_s_2_light

            name: 厨房灯

          - type: light

            entity: light.lemesh_cn_1155789492_wy0c15_s_2_light

            name: 餐厅灯

          - type: light

            entity: light.linp_cn_1137691863_lp1bc_s_2_light

            name: 卫生间灯

          - type: light

            entity: light.yeelink_cn_942773473_v11_s_2_light

            name: 浴霸灯

          - type: light

            entity: light.giot_cn_1188250021_v8ssm_s_2_light

            name: 走廊走道灯

          - type: light

            entity: light.linp_cn_2023072411_ld6bcw_s_2_light

            name: 走廊卫生间灯

          - type: light

            entity: light.linp_cn_2079761645_ld6bcw_s_2_light

            name: 门口筒灯



      # 今日亮灯时长（使用自动化写入的 _today_on_hours 传感器）
      - type: entities
        title: ⏱️ 今日亮灯时长统计
        entities:
          - entity: sensor.light_jdjz_today_on_hours
            name: 客厅吸顶灯
            icon: mdi:lightbulb-on
          - entity: sensor.light_sofa_today_on_hours
            name: 客厅沙发灯
            icon: mdi:lightbulb-on
          - entity: sensor.light_bedroom_strip_today_on_hours
            name: 卧室灯带
            icon: mdi:lightbulb-on
          - entity: sensor.light_kitchen_today_on_hours
            name: 厨房灯
            icon: mdi:lightbulb-on
          - entity: sensor.light_bathroom_today_on_hours
            name: 卫生间灯
            icon: mdi:lightbulb-on
          - entity: sensor.light_yuba_today_on_hours
            name: 浴霸灯
            icon: mdi:heat-wave
          - entity: sensor.light_hallway_main_today_on_hours
            name: 走廊走道灯
            icon: mdi:lightbulb-on
          - entity: sensor.light_hallway_bath_today_on_hours
            name: 走廊卫生间灯
            icon: mdi:lightbulb-on
          - entity: sensor.light_doorway_today_on_hours
            name: 门口筒灯
            icon: mdi:lightbulb-on
          - entity: sensor.all_lights_today_on_hours
            name: 全屋合计
            icon: mdi:home-lightbulb-outline



      # ==================== 温湿度监测 ====================

      # 温度曲线（9区域对比）
