# Template sensors for printer analytics - New syntax

# Fix for power consumption unit conversion
- sensor:
    name: yutai_cn_1169887446_fsov8m_power_consumption_kwh
    unique_id: yutai_cn_1169887446_fsov8m_power_consumption_kwh
    unit_of_measurement: kWh
    device_class: energy
    state_class: total_increasing
    icon: mdi:counter
    state: >
      {{ (states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1')|float(0) / 1000)|round(6) }}

# 打印机今日用电
- sensor:
    name: printer_daily_energy
    unique_id: printer_daily_energy
    unit_of_measurement: kWh
    device_class: energy
    icon: mdi:counter
    state: >
      {% set current = states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1')|float(0) %}
      {% set last_reset = now().replace(hour=0, minute=0, second=0, microsecond=0) %}
      {% set last_reset_str = last_reset.strftime('%Y-%m-%d %H:%M:%S') %}
      {% set last_state = states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1', last_reset_str)|float(0) %}
      {{ (current - last_state)|round(4) }}

# 打印机本周用电
- sensor:
    name: printer_weekly_energy
    unique_id: printer_weekly_energy
    unit_of_measurement: kWh
    device_class: energy
    icon: mdi:counter
    state: >
      {% set current = states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1')|float(0) %}
      {% set week_start = now().date() - timedelta(days=now().weekday()) %}
      {% set week_start_str = week_start.strftime('%Y-%m-%d') ~ ' 00:00:00' %}
      {% set week_start_state = states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1', week_start_str)|float(0) %}
      {{ (current - week_start_state)|round(4) }}

# 打印机本月用电
- sensor:
    name: printer_monthly_energy
    unique_id: printer_monthly_energy
    unit_of_measurement: kWh
    device_class: energy
    icon: mdi:counter
    state: >
      {% set current = states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1')|float(0) %}
      {% set month_start = now().date().replace(day=1) %}
      {% set month_start_str = month_start.strftime('%Y-%m-%d') ~ ' 00:00:00' %}
      {% set month_start_state = states('sensor.yutai_cn_1169887446_fsov8m_power_consumption_p_4_1', month_start_str)|float(0) %}
      {{ (current - month_start_state)|round(4) }}

