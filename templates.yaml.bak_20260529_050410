    name: 客厅灯今日亮灯
    unique_id: ke_ting_deng_jin_ri_v3
    unit_of_measurement: h
    icon: mdi:lightbulb-on
    state: >
      {{ ((states('sensor.light_jdjz_total_duration_hours')|float(0) + states('sensor.light_sofa_total_duration_hours')|float(0)) -
      (states('sensor.light_jdjz_total_duration_hours', now().replace(hour=0,minute=0,second=0,microsecond=0).strftime('%Y-%m-%d %H:%M:%S'))|float(0) +
