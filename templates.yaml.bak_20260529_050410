      {% set a1 = states('sensor.a1mini_0300aa5a1600497_total_usage') | float(0) %}
      {{ (p2s + a1) | round(1) }}

- sensor:
    name: "Print Duration Distribution"
    unique_id: printer_print_duration_distribution
    icon: "mdi:chart-bar"
    state: >
      {% set selected = states('input_select.print_analytics_time_range') %}
      {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
      {% set now_ts = as_timestamp(now()) %}
      {% set ns = namespace(a=0,b=0,c=0,d=0,e=0,f=0) %}
      {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
        {% for record in raw %}
          {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
          {% set duration = (record.duration_hours | float(0) * 60) %}
          {% if (days is none or (ts is not none and ts >= now_ts - days * 86400)) and duration > 0 %}
            {% if duration <= 30 %}
              {% set ns.a = ns.a + 1 %}
            {% elif duration <= 60 %}
              {% set ns.b = ns.b + 1 %}
            {% elif duration <= 180 %}
              {% set ns.c = ns.c + 1 %}
            {% elif duration <= 360 %}
              {% set ns.d = ns.d + 1 %}
            {% elif duration <= 720 %}
              {% set ns.e = ns.e + 1 %}
            {% else %}
              {% set ns.f = ns.f + 1 %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {{ ns.a + ns.b + ns.c + ns.d + ns.e + ns.f }}
    attributes:
      distribution: >
        {% set selected = states('input_select.print_analytics_time_range') %}
        {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
        {% set now_ts = as_timestamp(now()) %}
        {% set ns = namespace(a=0,b=0,c=0,d=0,e=0,f=0) %}
        {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
          {% for record in raw %}
            {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
            {% set duration = (record.duration_hours | float(0) * 60) %}
            {% if (days is none or (ts is not none and ts >= now_ts - days * 86400)) and duration > 0 %}
              {% if duration <= 30 %}
                {% set ns.a = ns.a + 1 %}
              {% elif duration <= 60 %}
                {% set ns.b = ns.b + 1 %}
              {% elif duration <= 180 %}
                {% set ns.c = ns.c + 1 %}
              {% elif duration <= 360 %}
                {% set ns.d = ns.d + 1 %}
              {% elif duration <= 720 %}
                {% set ns.e = ns.e + 1 %}
              {% else %}
                {% set ns.f = ns.f + 1 %}
              {% endif %}
            {% endif %}
          {% endfor %}
        {% endfor %}
        {{ {'0-30min': ns.a, '30min-1h': ns.b, '1-3h': ns.c, '3-6h': ns.d, '6-12h': ns.e, '12h+': ns.f} | to_json }}

- sensor:
    name: "Printer Activity Heatmap"
    unique_id: printer_activity_heatmap
    icon: "mdi:grid"
    state: >
      {% set selected = states('input_select.print_analytics_time_range') %}
      {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
      {% set now_ts = as_timestamp(now()) %}
      {% set ns = namespace(total=0) %}
      {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
        {% for record in raw %}
          {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
          {% if days is none or (ts is not none and ts >= now_ts - days * 86400) %}
            {% set ns.total = ns.total + 1 %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {{ ns.total }}
    attributes:
      heatmap_data: >
        {% set selected = states('input_select.print_analytics_time_range') %}
        {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
        {% set now_ts = as_timestamp(now()) %}
        {% set ns = namespace(data={}) %}
        {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
          {% for record in raw %}
            {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
            {% if days is none or (ts is not none and ts >= now_ts - days * 86400) %}
              {% set dt = as_datetime(record.start_time) if record.start_time is defined else none %}
              {% if dt %}
                {% set key = dt.strftime('%w-%H') %}
                {% set current = ns.data.get(key, 0) %}
                {% set ns.data = dict(ns.data, **{key: current + 1}) %}
              {% endif %}
            {% endif %}
          {% endfor %}
        {% endfor %}
        {{ ns.data | to_json }}

