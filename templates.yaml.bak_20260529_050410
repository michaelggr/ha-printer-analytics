# Printer total prints
- sensor:
    name: "Total Prints"
    unique_id: printer_total_prints
    unit_of_measurement: "count"
    icon: "mdi:printer-3d"
    state: >
      {% set selected = states('input_select.print_analytics_time_range') %}
      {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
      {% set now_ts = as_timestamp(now()) %}
      {% set ns = namespace(total=0) %}
      {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
        {% for record in raw %}
          {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
          {% if days is none or (ts is not none and ts >= now_ts - days * 86400) %}
            {% set ns.total = ns.total + 1 %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {{ ns.total }}

- sensor:
    name: "Success Rate"
    unique_id: printer_success_rate
    unit_of_measurement: "%"
    icon: "mdi:check-circle"
    state: >
      {% set selected = states('input_select.print_analytics_time_range') %}
      {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
      {% set now_ts = as_timestamp(now()) %}
      {% set ns = namespace(total=0, success=0) %}
      {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
        {% for record in raw %}
          {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
          {% if days is none or (ts is not none and ts >= now_ts - days * 86400) %}
            {% set ns.total = ns.total + 1 %}
            {% if record.status in ['finish', '完成', 'success', 'finished'] %}
              {% set ns.success = ns.success + 1 %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {{ ((ns.success / ns.total) * 100) | round(1) if ns.total > 0 else 0 }}

- sensor:
    name: "Average Print Duration"
    unique_id: printer_average_print_duration
    unit_of_measurement: "min"
    icon: "mdi:clock-outline"
    state: >
      {% set selected = states('input_select.print_analytics_time_range') %}
      {% set days = {'7d': 7, '30d': 30, '90d': 90}.get(selected) %}
      {% set now_ts = as_timestamp(now()) %}
      {% set ns = namespace(total=0, count=0) %}
      {% for raw in [state_attr('sensor.a1mini_a1mini_da_yin_li_shi', 'history') | default([], true), state_attr('sensor.p2s_p2s_da_yin_li_shi', 'history') | default([], true)] %}
        {% for record in raw %}
          {% set ts = as_timestamp(record.start_time) if record.start_time is defined else none %}
          {% set duration = (record.duration_hours | float(0) * 60) %}
          {% if (days is none or (ts is not none and ts >= now_ts - days * 86400)) and duration > 0 %}
            {% set ns.total = ns.total + duration %}
            {% set ns.count = ns.count + 1 %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {{ (ns.total / ns.count) | round(1) if ns.count > 0 else 0 }}

- sensor:
