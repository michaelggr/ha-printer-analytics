          "config": {
            "variables": {
              "XIAOMI_GATEWAY_VIRTUAL_EVENT": "notify.xiaomi_cn_1175403807_hub1_emit_virtual_event_a_4_1",
              "VIRTUAL_EVENT_NAME": "\u5c0f\u9ed1\u5974\u7092\u9762\u6682\u505c\u6253\u5370\u8bf7\u68c0\u67e5",
              "INTERNAL_HA_HOST_VAR": "http://192.168.0.130:8123",
              "PRINTER_CAMERA_VAR": "image.a1mini_0300aa5a1600497_camera",
              "BACKUP_CAMERA_VAR": null,
              "FAILURE_ACTION_VAR": "pause",
              "DETECTION_FREQUENCY_VAR": "/30",
              "AUTO_LIGHT_VAR": true,
              "QUALITY_CHECK_VAR": true,
              "QUALITY_THRESHOLD_VAR": 0.15,
              "MAX_IMAGE_AGE_VAR": 180,
              "AUTO_REFRESH_VAR": true,
              "REFRESH_SERVICE_VAR": "image.update",
              "PRINTER_PRINT_STATUS_SENSOR_VAR": "sensor.a1mini_0300aa5a1600497_print_status",
              "PRINTER_CHAMBER_LIGHT_VAR": "light.a1mini_0300aa5a1600497_chamber_light",
              "IMAGE_URL": "{% set main_entity = PRINTER_CAMERA_VAR %} {% set backup_entity = BACKUP_CAMERA_VAR %} {% set main_domain = main_entity.split('.')[0] if main_entity else 'image' %} {% set backup_domain = backup_entity.split('.')[0] if backup_entity else 'camera' %}\n{# \u68c0\u67e5\u4e3b\u6444\u50cf\u5934\u662f\u5426\u53ef\u7528 #} {% set main_available = main_entity and states(main_entity) not in ['unavailable', 'unknown', 'none'] %} {% set main_is_image = main_domain == 'image' %} {% set main_is_camera = main_domain == 'camera' %}\n{# \u6784\u5efa\u4e3b\u6444\u50cf\u5934URL #} {% if main_available %}\n  {% if main_is_image and state_attr(main_entity, 'access_token') %}\n    {{ INTERNAL_HA_HOST_VAR }}/api/image_proxy/{{ main_entity }}?token={{ state_attr(main_entity, 'access_token') }}\n  {% elif main_is_camera and state_attr(main_entity, 'entity_picture') %}\n    {{ INTERNAL_HA_HOST_VAR }}{{ state_attr(main_entity, 'entity_picture') }}\n  {% elif backup_entity and states(backup_entity) not in ['unavailable', 'unknown', 'none'] %}\n    {# \u4e3b\u6444\u50cf\u5934\u4e0d\u53ef\u7528\uff0c\u5207\u6362\u5230\u5907\u7528 #}\n    {% set backup_is_image = backup_domain == 'image' %}\n    {% if backup_is_image and state_attr(backup_entity, 'access_token') %}\n      {{ INTERNAL_HA_HOST_VAR }}/api/image_proxy/{{ backup_entity }}?token={{ state_attr(backup_entity, 'access_token') }}\n    {% else %}\n      {{ INTERNAL_HA_HOST_VAR }}{{ state_attr(backup_entity, 'entity_picture') }}\n    {% endif %}\n  {% else %}\n    {{ INTERNAL_HA_HOST_VAR }}/api/image_proxy/{{ main_entity }}?token={{ state_attr(main_entity, 'access_token') }}\n  {% endif %}\n{% elif backup_entity and states(backup_entity) not in ['unavailable', 'unknown', 'none'] %}\n  {# \u4e3b\u6444\u50cf\u5934\u5b8c\u5168\u4e0d\u53ef\u7528\uff0c\u4f7f\u7528\u5907\u7528 #}\n  {% if backup_is_image and state_attr(backup_entity, 'access_token') %}\n    {{ INTERNAL_HA_HOST_VAR }}/api/image_proxy/{{ backup_entity }}?token={{ state_attr(backup_entity, 'access_token') }}\n  {% else %}\n    {{ INTERNAL_HA_HOST_VAR }}{{ state_attr(backup_entity, 'entity_picture') }}\n  {% endif %}\n{% else %}\n  {# \u515c\u5e95\uff1a\u5c1d\u8bd5\u4e3b\u6444\u50cf\u5934 #}\n  {{ INTERNAL_HA_HOST_VAR }}/api/image_proxy/{{ main_entity }}?token={{ state_attr(main_entity, 'access_token') }}\n{% endif %}\n"
            },
            "mode": "single",
            "max_exceeded": "silent",
            "triggers": [
              {
                "platform": "state",
                "entity_id": [
                  "sensor.a1mini_0300aa5a1600497_current_stage"
                ],
                "to": "printing",
                "id": "BAMBU_LAB_PRINTER_STAGE_CHANGE"
              },
              {
                "platform": "time_pattern",
                "id": "BAMBU_LAB_DETECTION_TRIGGER",
                "seconds": "/30"
              },
              {
                "platform": "event",
                "event_type": "xiaomi_home_virtual_event",
                "id": "VIRTUAL_EVENT_PAUSE",
                "event_data": {
                  "event": "pause_print"
                }
              },
              {
                "platform": "event",
                "event_type": "xiaomi_home_virtual_event",
                "id": "VIRTUAL_EVENT_STOP",
                "event_data": {
                  "event": "stop_print"
                }
              }
            ],
            "actions": [
              {
                "choose": [
                  {
                    "conditions": [
                      {
                        "condition": "trigger",
                        "id": "BAMBU_LAB_PRINTER_STAGE_CHANGE"
                      }
                    ],
                    "sequence": [
                      {
                        "data": {
                          "value": 0
                        },
                        "target": {
                          "entity_id": [
                            "input_number.bambu_lab_p1_spaghetti_detection_current_frame_number",
                            "input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number",
                            "input_number.bambu_lab_p1_spaghetti_detection_ewm_mean",
                            "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short",
                            "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long",
                            "input_number.bambu_lab_p1_spaghetti_detection_normalized_p",
                            "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                            "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff",
                            "input_number.bambu_lab_p1_spaghetti_detection_thresh_warning",
                            "input_number.bambu_lab_p1_spaghetti_detection_thresh_failure",
                            "input_number.bambu_lab_p1_spaghetti_detection_p",
                            "input_number.bambu_lab_p1_spaghetti_detection_p_sum"
                          ]
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ is_state(PRINTER_CHAMBER_LIGHT_VAR, 'off') and AUTO_LIGHT_VAR }}"
                          }
                        ],
                        "then": [
                          {
                            "target": {
                              "entity_id": "light.a1mini_0300aa5a1600497_chamber_light"
                            },
                            "action": "light.turn_on"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "conditions": [
                      {
                        "condition": "trigger",
                        "id": "VIRTUAL_EVENT_PAUSE"
                      }
                    ],
                    "sequence": [
                      {
                        "data": {
                          "message": "\u6536\u5230\u7c73\u5bb6\u865a\u62df\u4e8b\u4ef6: pause_print\uff0c\u6267\u884c\u6682\u505c\u6253\u5370",
                          "level": "info"
                        },
                        "action": "system_log.write"
                      },
                      {
                        "target": {
                          "entity_id": "button.a1mini_0300aa5a1600497_pause_printing"
                        },
                        "action": "button.press"
                      }
                    ]
                  },
                  {
                    "conditions": [
                      {
                        "condition": "trigger",
                        "id": "VIRTUAL_EVENT_STOP"
                      }
                    ],
                    "sequence": [
                      {
                        "data": {
                          "message": "\u6536\u5230\u7c73\u5bb6\u865a\u62df\u4e8b\u4ef6: stop_print\uff0c\u6267\u884c\u505c\u6b62\u6253\u5370",
                          "level": "info"
                        },
                        "action": "system_log.write"
                      },
                      {
                        "target": {
                          "entity_id": "button.a1mini_0300aa5a1600497_stop_printing"
                        },
                        "action": "button.press"
                      }
                    ]
                  },
                  {
                    "conditions": [
                      {
                        "condition": "trigger",
                        "id": "BAMBU_LAB_DETECTION_TRIGGER"
                      }
                    ],
                    "sequence": [
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ not is_state(PRINTER_PRINT_STATUS_SENSOR_VAR, 'running') }}"
                          }
                        ],
                        "then": [
                          {
                            "stop": "Printer is not running."
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ is_state(PRINTER_CHAMBER_LIGHT_VAR, 'off') and AUTO_LIGHT_VAR }}"
                          }
                        ],
                        "then": [
                          {
                            "target": {
                              "entity_id": "light.a1mini_0300aa5a1600497_chamber_light"
                            },
                            "action": "light.turn_on"
                          }
                        ]
                      },
                      {
                        "variables": {
                          "main_entity": "{{ PRINTER_CAMERA_VAR }}",
                          "backup_entity": "{{ BACKUP_CAMERA_VAR }}",
                          "main_domain": "{{ main_entity.split('.')[0] }}",
                          "backup_domain": "{{ backup_entity.split('.')[0] if backup_entity else 'none' }}",
                          "main_last_updated": "{{ states[main_entity].last_updated if states[main_entity] is not none else now() }}",
                          "main_age_seconds": "{{ ((now() - main_last_updated | as_datetime | as_local).total_seconds()) | int }}",
                          "main_is_stale": "{{ main_age_seconds > MAX_IMAGE_AGE_VAR }}",
                          "main_needs_refresh": "{{ main_age_seconds > MAX_IMAGE_AGE_VAR and AUTO_REFRESH_VAR }}",
                          "main_entity_state": "{{ states(main_entity) }}",
                          "main_has_attr": "{{ state_attr(main_entity, 'access_token') != None or state_attr(main_entity, 'entity_picture') != None }}",
                          "main_is_available": "{{ main_entity_state not in ['unavailable', 'unknown', 'none'] and main_has_attr and not main_is_stale }}",
                          "backup_last_updated": "{{ states[backup_entity].last_updated if backup_entity and states[backup_entity] is not none else now() }}",
                          "backup_age_seconds": "{{ ((now() - backup_last_updated | as_datetime | as_local).total_seconds()) | int }}",
                          "backup_is_stale": "{{ backup_age_seconds > MAX_IMAGE_AGE_VAR }}",
                          "backup_entity_state": "{{ states(backup_entity) if backup_entity else 'none' }}",
                          "backup_has_attr": "{{ state_attr(backup_entity, 'access_token') != None or state_attr(backup_entity, 'entity_picture') != None if backup_entity else false }}",
                          "backup_is_available": "{{ backup_entity and backup_entity_state not in ['unavailable', 'unknown', 'none'] and backup_has_attr and not backup_is_stale }}",
                          "use_backup": "{{ not main_is_available and backup_is_available }}",
                          "active_entity": "{{ backup_entity if use_backup else main_entity }}"
                        }
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ QUALITY_CHECK_VAR }}"
                          }
                        ],
                        "then": [
                          {
                            "if": [
                              {
                                "condition": "template",
                                "value_template": "{{ main_is_stale }}"
                              }
                            ],
                            "then": [
                              {
                                "choose": [
                                  {
                                    "conditions": [
                                      {
                                        "condition": "template",
                                        "value_template": "{{ main_needs_refresh and REFRESH_SERVICE_VAR | length > 0 }}"
                                      }
                                    ],
                                    "sequence": [
                                      {
                                        "data": {
                                          "message": "Main camera image stale ({{ main_age_seconds | int }}s), attempting refresh",
                                          "level": "info"
                                        },
                                        "action": "system_log.write"
                                      },
                                      {
                                        "target": {
                                          "entity_id": "{{ main_entity }}"
                                        },
                                        "action": "{{ REFRESH_SERVICE_VAR }}"
                                      },
                                      {
                                        "delay": {
                                          "seconds": 2
                                        }
                                      },
                                      {
                                        "variables": {
                                          "refreshed_last_updated": "{{ states[main_entity].last_updated if states[main_entity] is not none else now() }}",
                                          "refreshed_age": "{{ (now() - refreshed_last_updated | as_datetime | as_local).total_seconds() }}",
                                          "refresh_success": "{{ refreshed_age < MAX_IMAGE_AGE_VAR }}"
                                        }
                                      },
                                      {
                                        "if": [
                                          {
                                            "condition": "template",
                                            "value_template": "{{ not refresh_success and not backup_is_available }}"
                                          }
                                        ],
                                        "then": [
                                          {
                                            "stop": "Main camera refresh failed and no backup available"
                                          }
                                        ]
                                      },
                                      {
                                        "if": [
                                          {
                                            "condition": "template",
                                            "value_template": "{{ not refresh_success and backup_is_available }}"
                                          }
                                        ],
                                        "then": [
                                          {
                                            "data": {
                                              "message": "Main camera refresh failed, will use backup",
                                              "level": "warning"
                                            },
                                            "action": "system_log.write"
                                          }
                                        ]
                                      }
                                    ]
                                  },
                                  {
                                    "conditions": [
                                      {
                                        "condition": "template",
                                        "value_template": "{{ not backup_is_available }}"
                                      }
                                    ],
                                    "sequence": [
                                      {
                                        "stop": "Main camera image too old ({{ main_age_seconds | int }}s) and no backup available"
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "if": [
                              {
                                "condition": "template",
                                "value_template": "{{ not main_has_attr }}"
                              }
                            ],
                            "then": [
                              {
                                "if": [
                                  {
                                    "condition": "template",
                                    "value_template": "{{ not backup_is_available }}"
                                  }
                                ],
                                "then": [
                                  {
                                    "stop": "Main camera has no image attributes and no backup available"
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "if": [
                              {
                                "condition": "template",
                                "value_template": "{{ main_entity_state in ['unavailable', 'unknown', 'none'] }}"
                              }
                            ],
                            "then": [
                              {
                                "if": [
                                  {
                                    "condition": "template",
                                    "value_template": "{{ not backup_is_available }}"
                                  }
                                ],
                                "then": [
                                  {
                                    "stop": "Main camera is {{ main_entity_state }} and no backup available"
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "if": [
                              {
                                "condition": "template",
                                "value_template": "{{ use_backup }}"
                              }
                            ],
                            "then": [
                              {
                                "data": {
                                  "message": "Main camera quality check failed, switching to backup: {{ active_entity }}",
                                  "level": "warning"
                                },
                                "action": "system_log.write"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "data": {
                          "image_url": "{{ IMAGE_URL }}"
                        },
                        "response_variable": "result",
                        "action": "shell_command.obico_detect"
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ result.returncode | int(1) != 0 }}"
                          }
                        ],
                        "then": [
                          {
                            "stop": "Obico detect shell command failed"
                          }
                        ]
                      },
                      {
                        "variables": {
                          "detection_result": "{{ result.stdout | default('{\"detections\": []}', true) | from_json }}"
                        }
                      },
                      {
                        "data": {
                          "value": "{{ detection_result.detections | default([], true) | map(attribute=1) | sum | float }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p_sum"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ states('input_number.bambu_lab_p1_spaghetti_detection_current_frame_number') | float + 1 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_current_frame_number"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ states('input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number') | float + 1 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_p_sum') | float) * (2 / (12 + 1)) + (states('input_number.bambu_lab_p1_spaghetti_detection_ewm_mean') | float) * (1 - (2 / (12 + 1))) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_ewm_mean"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short') | float) + ((states('input_number.bambu_lab_p1_spaghetti_detection_p_sum') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short') | float)) / (310 if 310 <= (states('input_number.bambu_lab_p1_spaghetti_detection_current_frame_number') | float) else (states('input_number.bambu_lab_p1_spaghetti_detection_current_frame_number') | float) + 1) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float) + ((states('input_number.bambu_lab_p1_spaghetti_detection_p_sum') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float)) / (7200 if 7200 <= (states('input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number') | float) else (states('input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number') | float) + 1) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "if": [
                          {
                            "condition": "numeric_state",
                            "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_current_frame_number",
                            "below": 30
                          }
                        ],
                        "then": [
                          {
                            "stop": "Warming up logic"
                          }
                        ]
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_ewm_mean') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ ((states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float)) * 3.8 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ min(0.78, max(0.33, (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff') | float))) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_thresh_warning"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float) * 1.75 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_thresh_failure"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_ewm_mean') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "choose": [
                          {
                            "conditions": [
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p",
                                "above": "input_number.bambu_lab_p1_spaghetti_detection_thresh_failure"
                              }
                            ],
                            "sequence": [
                              {
                                "data": {
                                  "value": "{{ min(1.0, max(2.0 / 3.0, ((((states('input_number.bambu_lab_p1_spaghetti_detection_p') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float)) * (1.0 - 2.0 / 3.0)) / ((states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float) * 1.5 - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float))) + 2.0 / 3.0)) }}"
                                },
                                "target": {
                                  "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_normalized_p"
                                },
                                "action": "input_number.set_value"
                              }
                            ]
                          },
                          {
                            "conditions": [
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p",
                                "above": "input_number.bambu_lab_p1_spaghetti_detection_thresh_warning"
                              }
                            ],
                            "sequence": [
                              {
                                "data": {
                                  "value": "{{ min(2.0 / 3.0, max(1.0 / 3.0, ((((states('input_number.bambu_lab_p1_spaghetti_detection_p') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float)) * (2.0 / 3.0 - 1.0 / 3.0)) / ((states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float))) + 1.0 / 3.0)) }}"
                                },
                                "target": {
                                  "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_normalized_p"
                                },
                                "action": "input_number.set_value"
                              }
                            ]
                          }
                        ],
                        "default": [
                          {
                            "data": {
                              "value": "{{ min(1.0 / 3.0, max(0, ((states('input_number.bambu_lab_p1_spaghetti_detection_p') | float) * 1.0 / 3.0) / (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float))) }}"
                            },
                            "target": {
                              "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_normalized_p"
                            },
                            "action": "input_number.set_value"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "numeric_state",
                            "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                            "below": 0.38
                          }
                        ],
                        "then": [
                          {
                            "stop": "Low probability"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "and",
                            "conditions": [
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                                "below": 0.78
                              },
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                                "below": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff"
                              }
                            ]
                          }
                        ],
                        "then": [
                          {
                            "stop": "Below adaptive threshold"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ now() - states('input_datetime.bambu_lab_p1_spaghetti_detection_last_notify_time') | as_datetime | as_local < timedelta(minutes=1) }}"
                          }
                        ],
                        "then": [
                          {
                            "stop": "Notification cooldown"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ states('input_number.bambu_lab_p1_spaghetti_detection_normalized_p') | float > 0.7 }}"
                          }
                        ],
                        "then": [
                          {
                            "target": {
                              "entity_id": "{{ XIAOMI_GATEWAY_VIRTUAL_EVENT }}"
                            },
                            "data": {
                              "message": "{{ VIRTUAL_EVENT_NAME }}",
                              "data": {
                                "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_normalized_p') | float * 100) | int }}"
                              }
                            },
                            "action": "notify.send_message"
                          },
                          {
                            "data": {
                              "datetime": "{{ now().strftime('%Y-%m-%d %H:%M:%S') }}"
                            },
                            "target": {
                              "entity_id": "input_datetime.bambu_lab_p1_spaghetti_detection_last_notify_time"
                            },
                            "action": "input_datetime.set_datetime"
                          },
                          {
                            "choose": [
                              {
                                "conditions": [
                                  {
                                    "condition": "template",
                                    "value_template": "{{ FAILURE_ACTION_VAR == 'pause' }}"
                                  }
                                ],
                                "sequence": [
                                  {
                                    "target": {
                                      "entity_id": "button.a1mini_0300aa5a1600497_pause_printing"
                                    },
                                    "action": "button.press"
                                  }
                                ]
                              },
                              {
                                "conditions": [
                                  {
                                    "condition": "template",
                                    "value_template": "{{ FAILURE_ACTION_VAR == 'stop' }}"
                                  }
                                ],
                                "sequence": [
                                  {
                                    "target": {
                                      "entity_id": "button.a1mini_0300aa5a1600497_stop_printing"
                                    },
                                    "action": "button.press"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
