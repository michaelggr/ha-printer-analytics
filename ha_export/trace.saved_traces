?token={{ state_attr(backup_entity, 'access_token') }}\n  {% else %}\n    {{ INTERNAL_HA_HOST_VAR }}{{ state_attr(backup_entity, 'entity_picture') }}\n  {% endif %}\n{% else %}\n  {# \u515c\u5e95\uff1a\u5c1d\u8bd5\u4e3b\u6444\u50cf\u5934 #}\n  {{ INTERNAL_HA_HOST_VAR }}/api/image_proxy/{{ main_entity }}?token={{ state_attr(main_entity, 'access_token') }}\n{% endif %}\n"
