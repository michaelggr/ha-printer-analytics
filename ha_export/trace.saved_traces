                "value_template": "{{ state_attr('event.xiaomi_cn_1175403807_hub1_virtual_event_e_4_1', '\u4e8b\u4ef6\u540d\u79f0') == '\u6253\u5370\u5269\u4f59\u65f6\u95f4' }}"
