              {
                "target": {
                  "entity_id": "notify.xiaomi_cn_338143536_lx5a_play_text_a_5_1"
                },
                "data": {
                  "message": "{% set a1mini = states('sensor.a1mini_0300aa5a1600497_remaining_time') %} {% set p2s = states('sensor.p2s_22e8bj5a2401765_remaining_time') %} {% set now = now() %}\n{% macro format_time(hours, mins) %}\n  {% if hours > 0 and mins > 0 %}\n    {{ hours }}\u5c0f\u65f6{{ mins }}\u5206\u949f\n  {% elif hours > 0 %}\n    {{ hours }}\u5c0f\u65f6\n  {% elif mins > 0 %}\n    {{ mins }}\u5206\u949f\n  {% else %}\n    \u5373\u5c06\u5b8c\u6210\n  {% endif %}\n{% endmacro %}\n{% macro get_completion_time(remaining) %}\n  {% if remaining != 'unknown' %}\n    {{ (now + timedelta(hours=remaining | float(0))).strftime('%H:%M') }}\n  {% else %}\n    \u672a\u77e5\n  {% endif %}\n{% endmacro %}\n{% set a1mini_hours = a1mini | float(0) | int %} {% set a1mini_mins = ((a1mini | float(0) - a1mini_hours) * 60) | int %} {% set p2s_hours = p2s | float(0) | int %} {% set p2s_mins = ((p2s | float(0) - p2s_hours) * 60) | int %}\n{% if a1mini != 'unknown' and a1mini | float > 0 and p2s != 'unknown' and p2s | float > 0 %}\n  \u6253\u5370\u4e2d\uff0c\u5c0f\u9ed1\u5974\u5269\u4f59{{ format_time(a1mini_hours, a1mini_mins) }}\uff0c\u9884\u8ba1{{ get_completion_time(a1mini) }}\u5b8c\u6210\uff1b\u5927\u9ed1\u5974\u5269\u4f59{{ format_time(p2s_hours, p2s_mins) }}\uff0c\u9884\u8ba1{{ get_completion_time(p2s) }}\u5b8c\u6210\u3002\n{% elif a1mini != 'unknown' and a1mini | float > 0 %}\n  \u6253\u5370\u4e2d\uff0c\u5c0f\u9ed1\u5974\u5269\u4f59{{ format_time(a1mini_hours, a1mini_mins) }}\uff0c\u9884\u8ba1{{ get_completion_time(a1mini) }}\u5b8c\u6210\u3002\n{% elif p2s != 'unknown' and p2s | float > 0 %}\n  \u6253\u5370\u4e2d\uff0c\u5927\u9ed1\u5974\u5269\u4f59{{ format_time(p2s_hours, p2s_mins) }}\uff0c\u9884\u8ba1{{ get_completion_time(p2s) }}\u5b8c\u6210\u3002\n{% else %}\n  \u5f53\u524d\u6ca1\u6709\u6b63\u5728\u8fdb\u884c\u7684\u6253\u5370\u4efb\u52a1\u3002\n{% endif %}\n"
