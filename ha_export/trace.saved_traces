                                  "level": "warning"
                                },
                                "action": "system_log.write"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "data": {
                          "image_url": "{{ IMAGE_URL }}"
                        },
                        "response_variable": "result",
                        "action": "shell_command.obico_detect"
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
                            "value_template": "{{ result.returncode | int(1) != 0 }}"
                          }
                        ],
                        "then": [
                          {
                            "stop": "Obico detect shell command failed"
                          }
                        ]
                      },
                      {
                        "variables": {
                          "detection_result": "{{ result.stdout | default('{\"detections\": []}', true) | from_json }}"
                        }
                      },
                      {
                        "data": {
                          "value": "{{ detection_result.detections | default([], true) | map(attribute=1) | sum | float }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p_sum"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ states('input_number.bambu_lab_p1_spaghetti_detection_current_frame_number') | float + 1 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_current_frame_number"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ states('input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number') | float + 1 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_p_sum') | float) * (2 / (12 + 1)) + (states('input_number.bambu_lab_p1_spaghetti_detection_ewm_mean') | float) * (1 - (2 / (12 + 1))) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_ewm_mean"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short') | float) + ((states('input_number.bambu_lab_p1_spaghetti_detection_p_sum') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short') | float)) / (310 if 310 <= (states('input_number.bambu_lab_p1_spaghetti_detection_current_frame_number') | float) else (states('input_number.bambu_lab_p1_spaghetti_detection_current_frame_number') | float) + 1) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float) + ((states('input_number.bambu_lab_p1_spaghetti_detection_p_sum') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float)) / (7200 if 7200 <= (states('input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number') | float) else (states('input_number.bambu_lab_p1_spaghetti_detection_lifetime_frame_number') | float) + 1) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "if": [
                          {
                            "condition": "numeric_state",
                            "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_current_frame_number",
                            "below": 30
                          }
                        ],
                        "then": [
                          {
                            "stop": "Warming up logic"
                          }
                        ]
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_ewm_mean') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ ((states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_short') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float)) * 3.8 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ min(0.78, max(0.33, (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff') | float))) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_thresh_warning"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float) * 1.75 }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_thresh_failure"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "data": {
                          "value": "{{ (states('input_number.bambu_lab_p1_spaghetti_detection_ewm_mean') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_long') | float) }}"
                        },
                        "target": {
                          "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p"
                        },
                        "action": "input_number.set_value"
                      },
                      {
                        "choose": [
                          {
                            "conditions": [
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p",
                                "above": "input_number.bambu_lab_p1_spaghetti_detection_thresh_failure"
                              }
                            ],
                            "sequence": [
                              {
                                "data": {
                                  "value": "{{ min(1.0, max(2.0 / 3.0, ((((states('input_number.bambu_lab_p1_spaghetti_detection_p') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float)) * (1.0 - 2.0 / 3.0)) / ((states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float) * 1.5 - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float))) + 2.0 / 3.0)) }}"
                                },
                                "target": {
                                  "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_normalized_p"
                                },
                                "action": "input_number.set_value"
                              }
                            ]
                          },
                          {
                            "conditions": [
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_p",
                                "above": "input_number.bambu_lab_p1_spaghetti_detection_thresh_warning"
                              }
                            ],
                            "sequence": [
                              {
                                "data": {
                                  "value": "{{ min(2.0 / 3.0, max(1.0 / 3.0, ((((states('input_number.bambu_lab_p1_spaghetti_detection_p') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float)) * (2.0 / 3.0 - 1.0 / 3.0)) / ((states('input_number.bambu_lab_p1_spaghetti_detection_thresh_failure') | float) - (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float))) + 1.0 / 3.0)) }}"
                                },
                                "target": {
                                  "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_normalized_p"
                                },
                                "action": "input_number.set_value"
                              }
                            ]
                          }
                        ],
                        "default": [
                          {
                            "data": {
                              "value": "{{ min(1.0 / 3.0, max(0, ((states('input_number.bambu_lab_p1_spaghetti_detection_p') | float) * 1.0 / 3.0) / (states('input_number.bambu_lab_p1_spaghetti_detection_thresh_warning') | float))) }}"
                            },
                            "target": {
                              "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_normalized_p"
                            },
                            "action": "input_number.set_value"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "numeric_state",
                            "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                            "below": 0.38
                          }
                        ],
                        "then": [
                          {
                            "stop": "Low probability"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "and",
                            "conditions": [
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                                "below": 0.78
                              },
                              {
                                "condition": "numeric_state",
                                "entity_id": "input_number.bambu_lab_p1_spaghetti_detection_adjusted_ewm_mean",
                                "below": "input_number.bambu_lab_p1_spaghetti_detection_rolling_mean_diff"
                              }
                            ]
                          }
                        ],
                        "then": [
                          {
                            "stop": "Below adaptive threshold"
                          }
                        ]
                      },
                      {
                        "if": [
                          {
                            "condition": "template",
